BOT_TOKEN=

# Германская панель
GERMAN_PANEL_HOME_URL=
# API-токен панели (3x-ui → Settings → Security/API). Authorization: Bearer
XUI_API_TOKEN_GERM=
# База для ссылки подписки (напр. https://bimbambom.site:2096/sub/)
GERM_SUB_BASE_URL=
# ID inbound'ов (по умолчанию WS=3, XHTTP=2)
# GERM_WS_INBOUND=3
# GERM_XHTTP_INBOUND=2

# Латвийская панель
LATV_PANEL_HOME_URL=
# API-токен панели (3x-ui → Settings → Security/API). Authorization: Bearer
XUI_API_TOKEN_LATV=
# База для ссылки подписки (по умолчанию https://petromerzlikino.site:2096/sub/)
# LATV_SUB_BASE_URL=
# ID inbound'ов на Latvian панели (по умолчанию WS prod=2/dev=3).
# LATV_WS_INBOUND_PROD=2
# LATV_WS_INBOUND_DEV=3
# XHTTP inbound ID. Если не задан — XHTTP для Латвии отключён.
# LATV_XHTTP_INBOUND_PROD=
# LATV_XHTTP_INBOUND_DEV=

# Примечание: vless/xhttp-ссылки теперь генерирует сама панель
# (GET /panel/api/clients/links/{email}), поэтому ручные xHTTP-параметры
# (порты, host, pbk/sni/sid/fp/path/spx) больше не нужны.

DB_LINK_PROD=
DB_LINK_DEV=

DB_USER=
DB_PASSWORD=
DB_NAME=

ADMIN_CHATS=
