# Inbound IDs на Latvian панели
# LATV_XHTTP_INBOUND_PROD=
# LATV_XHTTP_INBOUND_DEV=

# xHTTP Reality-параметры (Латвия)
# LATV_XHTTP_PORT=443
# LATV_XHTTP_PATH=/api/v1/sync
# LATV_XHTTP_PBK=
# LATV_XHTTP_SNI=
# LATV_XHTTP_SID=
# LATV_XHTTP_FP=chrome
# LATV_XHTTP_SPX=/

# Германский сервер — параметры VLESS-ссылок
# GERM_SERVER_HOST=         # hostname/IP в VLESS-ссылках (напр. bimbambom.site)
# GERM_WS_PORT=1235         # порт WS inbound (id=3)
# GERM_XHTTP_PORT=54228     # порт XHTTP inbound (id=2)
# GERM_SUB_BASE_URL=        # база для ссылки подписки (напр. https://bimbambom.site:2096/sub/)

# xHTTP Reality-параметры (Германия) — берутся из настроек XHTTP inbound id=2 на панели
# GERM_XHTTP_PBK=Dk8_9uV1gUvo_1zf-n_oOBLuEaUxzae0u5lPz5aTDB4
# GERM_XHTTP_SNI=www.sap.com
# GERM_XHTTP_SID=11ba67e3b7
# GERM_XHTTP_FP=chrome
# GERM_XHTTP_PATH=/
# GERM_XHTTP_HOST=www.sap.com
# GERM_XHTTP_SPX=/

